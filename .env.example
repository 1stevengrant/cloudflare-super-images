# Copy to .env (which is git-ignored) and fill in real values.
# Loaded by Vite + the Cloudflare Vite plugin during local dev.

# Your Cloudflare Account ID (Dashboard → right sidebar, or any product page).
CF_ACCOUNT_ID=""

# Public-safe hash used in delivery URLs (imagedelivery.net/<HASH>/<id>/...).
# Dashboard → Images → Hosted Images → Developer Resources → "Account Hash".
CF_ACCOUNT_HASH=""

# An API token with "Images: Edit" permission.
# Used only to mint Direct Creator Upload URLs; hosted-image metadata/delete
# operations use the Worker IMAGES binding.
# Create at: https://dash.cloudflare.com/profile/api-tokens
#   → "Create Token" → "Custom token"
#   → Permissions: Account → Cloudflare Images → Edit
#   → Account Resources: Include → <your account>
CF_IMAGES_TOKEN=""
