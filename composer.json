{
    "name": "ghijk/cloudflare-super-images",
    "description": "A Laravel package for Cloudflare Images: build delivery URLs, mint direct creator uploads, and manage assets.",
    "keywords": [
        "ghijk",
        "laravel",
        "cloudflare",
        "cloudflare-images",
        "images",
        "cdn"
    ],
    "homepage": "https://github.com/1stevengrant/cloudflare-super-images",
    "license": "MIT",
    "authors": [
        {
            "name": "Steven Grant",
            "email": "steven@ghijk.co.uk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^10.0||^11.0||^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "larastan/larastan": "^2.9||^3.0",
        "laravel/pint": "^1.14",
        "orchestra/testbench": "^8.0||^9.0||^10.0",
        "pestphp/pest": "^2.34||^3.0",
        "pestphp/pest-plugin-laravel": "^2.3||^3.0",
        "phpstan/phpstan": "^1.11||^2.0"
    },
    "autoload": {
        "psr-4": {
            "Ghijk\\CloudflareSuperImages\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ghijk\\CloudflareSuperImages\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ghijk\\CloudflareSuperImages\\CloudflareSuperImagesServiceProvider"
            ],
            "aliases": {
                "CloudflareImages": "Ghijk\\CloudflareSuperImages\\Facades\\CloudflareImages"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
